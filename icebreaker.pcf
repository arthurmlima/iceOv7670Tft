# iCEBreaker 12 MHz oscillator
set_io -nowarn CLK 35

# Explicit constraint for the internally divided PicoRV32 clock.  The primary
# video clock remains constrained by Makefile FREQ=39.00.
set_frequency clk_cpu 9.75

# On-board active-low button and LEDs
set_io -nowarn BTN_N 10
set_io -nowarn LEDR_N 11
set_io -nowarn LEDG_N 37

# PicoSoC UART
set_io -nowarn uart_rx 6
set_io -nowarn uart_tx 9

# Onboard SPI flash (firmware reset vector is at byte offset 0x0010_0000)
set_io -nowarn flash_clk 15
set_io -nowarn flash_csb 16
set_io -nowarn flash_io0 14
set_io -nowarn flash_io1 17
set_io -nowarn flash_io2 12
set_io -nowarn flash_io3 13

# ----------------------------------------------------------------------
# ST7789: keep the existing known-working six display signals on PMOD 2
# ----------------------------------------------------------------------
set_io -nowarn tft_scl 27   # P2B1
set_io -nowarn tft_sda 25   # P2B2
set_io -nowarn tft_res 21   # P2B3
set_io -nowarn tft_dc  19   # P2B4
set_io -nowarn tft_cs  26   # P2B7
set_io -nowarn tft_blk 23   # P2B8


# ----------------------------------------------------------------------
# OV7670 8-bit data bus on PMOD 1A
# ----------------------------------------------------------------------
set_io -nowarn cam_siod  4    # P1A1
set_io -nowarn cam_href  2    # P1A2
set_io -nowarn cam_xclk  47   # P1A3
set_io -nowarn cam_pwdn  45   # P1A4
set_io -nowarn cam_sioc  3    # P1A7
set_io -nowarn cam_vsync 48   # P1A8
set_io -nowarn cam_pclk  46   # P1A9
set_io -nowarn cam_rst_n 44   # P1A10



# ----------------------------------------------------------------------
# OV7670 8-bit data bus on PMOD 1B
# ----------------------------------------------------------------------
set_io -nowarn cam_d[0] 43   # P1B1
set_io -nowarn cam_d[1] 38   # P1B2
set_io -nowarn cam_d[2] 34   # P1B3
set_io -nowarn cam_d[3] 31   # P1B4
set_io -nowarn cam_d[4] 42   # P1B7
set_io -nowarn cam_d[5] 36   # P1B8
set_io -nowarn cam_d[6] 32   # P1B9
set_io -nowarn cam_d[7] 28   # P1B10
